# 忽略Python缓存
__pycache__/
*.py[cod]
*$py.class
*.so

# 忽略虚拟环境
venv/
env/
ENV/

# 忽略IDE配置
.vscode/
.idea/
*.swp
*.swo

# 忽略原始美术素材（源文件）
美术素材/
assets_transparent/
*.mp4

# 允许 assets/ 目录下的游戏资产
# 但排除过大的原始素材格式
*.psd
*.xcf
*.aseprite

# 忽略非资产目录的图片
# （assets/ 内的 PNG 会被 git 追踪）

# 忽略存档
saves/
*.sav

# 忽略日志
*.log

# 忽略临时文件
*.tmp
*.bak
~*

# 忽略系统文件
.DS_Store
Thumbs.db

# 忽略打包文件
dist/
build/
*.egg-info/

# 忽略测试覆盖率
.coverage
htmlcov/

# 忽略文档生成
docs/_build/
